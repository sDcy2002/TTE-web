<%- include('partials/header') %>

<div class="page-container" style="max-width:500px; margin:0 auto;">
  <h2 class="text-gradient" style="margin-bottom:20px;">Login / Register</h2>
  <form id="auth-form" style="display:flex; flex-direction:column; gap:15px;">
    <input type="text" id="username" placeholder="Username" required style="padding:10px; font-size:16px;">
    <input type="password" id="password" placeholder="Password" required style="padding:10px; font-size:16px;">
    <button type="submit" class="bg-gradient" style="padding:12px; border:none; border-radius:8px; color:#fff; font-size:16px; font-weight:bold; cursor:pointer;">Submit</button>
  </form>
  <p style="margin-top:20px; color:#666;">
    <span id="toggle-text"></span>
    <span id="toggle-link" style="color:#1a499b; font-weight:bold; cursor:pointer; text-decoration:underline;"></span>
  </p>
</div>

<%- include('partials/footer') %>

<script src="/js/register.js"></script>